generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  NURSE_TRIAGE
  CASHIER
  DOCTOR
  ADMIN
  CONSULTOR
}

enum TriageColor {
  VERDE
  AMARILLO
  ROJO
}

enum Sex {
  M
  F
  O
}

enum PaymentStatus {
  PENDING
  PAID
}

enum CloseReason {
  CASHIER_FINISHED // cierre por caja (motivos no-consulta)
  REFUSED_PAYMENT // no quiso pagar
  NO_SHOW // no se presentó al llamado (doctor)
  DOCTOR_FINISHED // finalizado por doctor
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  cedula       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  triagesAsNurse    TriageRecord[] @relation("NurseTriage")
  notesAsDoctor     MedicalNote[]  @relation("DoctorNote")
  paymentsAsCashier Payment[]      @relation("CashierPayment")

  // ✅ para NO-SHOW (doctor marca no-show en triageRecord)
  noShowsAsDoctor TriageRecord[] @relation("DoctorNoShow")
}

model Patient {
  id              Int       @id @default(autoincrement())
  expediente      String?   @unique
  fullName        String
  birthDate       DateTime?
  age             String?
  sex             Sex?
  mayaHabla       Boolean   @default(false)
  responsibleName String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  triages TriageRecord[]
}

model TriageRecord {
  id        Int @id @default(autoincrement())
  patientId Int
  nurseId   Int

  motivoUrgencia String
  triageAt       DateTime @default(now())

  // ✅ nuevo: observaciones de enfermería (siempre visible)
  observaciones String? @db.Text

  // Semáforo por parámetro
  appearance  TriageColor
  respiration TriageColor
  circulation TriageColor

  // Clasificación final (verde/amarillo/rojo)
  classification TriageColor

  // Signos vitales
  weightKg        Float?
  heightCm        Float?
  temperatureC    Float?
  heartRate       Int?
  respiratoryRate Int?
  bloodPressure   String?

  // Flags + lugar
  hadPriorCareSamePathology Boolean @default(false)
  priorCarePlace            String?
  hasReferral               Boolean @default(false)
  referralPlace             String?

  // Pago
  paidStatus PaymentStatus @default(PENDING)

  // ✅ cierres (termina el flujo sin médico)
  closedAt       DateTime?
  closedReason   CloseReason?
  refusedPayment Boolean      @default(false)

  // ✅ no-show (doctor)
  noShow         Boolean   @default(false)
  noShowReason   String?   @db.Text
  noShowAt       DateTime?
  noShowDoctorId Int?
  noShowDoctor   User?     @relation("DoctorNoShow", fields: [noShowDoctorId], references: [id])

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurse   User    @relation("NurseTriage", fields: [nurseId], references: [id])

  payment     Payment?
  medicalNote MedicalNote?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([triageAt])
  @@index([classification])
  @@index([paidStatus])
  @@index([closedAt])
  @@index([refusedPayment])
  @@index([noShow])
}

model Payment {
  id        Int @id @default(autoincrement())
  triageId  Int @unique
  cashierId Int

  status PaymentStatus @default(PAID)
  paidAt DateTime      @default(now())

  // ✅ ya no lo capturan, lo dejamos opcional para no romper migraciones previas
  amount Decimal? @db.Decimal(10, 2)

  triage  TriageRecord @relation(fields: [triageId], references: [id], onDelete: Cascade)
  cashier User         @relation("CashierPayment", fields: [cashierId], references: [id])

  createdAt DateTime @default(now())
}

model MedicalNote {
  id       Int @id @default(autoincrement())
  triageId Int @unique
  doctorId Int

  consultationStartedAt  DateTime?
  consultationFinishedAt DateTime?

  padecimientoActual   String  @db.Text
  antecedentes         String  @db.Text
  exploracionFisica    String  @db.Text
  estudiosParaclinicos String  @db.Text
  diagnostico          String  @db.Text
  diagnosisPrincipal   String?
  planTratamiento      String  @db.Text

  // ✅ antes era Json checkboxes; ahora será texto libre (campo libre)
  vigilanciaTexto String? @db.Text

  // contrarreferencia (si/no + tiempo)
  contraRefFollowUp Boolean @default(false)
  contraRefWhen     String?

  // (si lo estabas usando en algún lado, lo dejamos; si no, después lo quitamos)
  contrarreferencia String @db.Text

  pronostico String @db.Text

  triage TriageRecord @relation(fields: [triageId], references: [id], onDelete: Cascade)
  doctor User         @relation("DoctorNote", fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consultationStartedAt])
}
